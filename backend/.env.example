# URL del servidor local de Ollama
OLLAMA_URL=http://localhost:11434

# Modelo de chat usado para clasificacion, triage orientativo y RAG
OLLAMA_CHAT_MODEL=qwen2.5:3b

# Modelo de embeddings usado para indexar y consultar los RAG
OLLAMA_EMBED_MODEL=nomic-embed-text

# Umbral minimo de confianza del clasificador; por debajo se fuerza "no_se"
CONFIANZA_MINIMA=0.6

# Cantidad de fragmentos recuperados por consulta RAG
RAG_TOP_K=6

# Similitud minima (0-1) para considerar un fragmento relevante en el RAG
RAG_SIMILITUD_MINIMA=0.3

# Timeout en segundos para llamadas a Ollama
OLLAMA_TIMEOUT=60
